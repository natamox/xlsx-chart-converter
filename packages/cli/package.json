{
  "name": "@natamox/xlsx-chart-converter-cli",
  "version": "0.2.0",
  "description": "CLI for inspecting and exporting Excel OOXML charts.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "xlsx-chart-converter": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@natamox/xlsx-chart-converter-core": "workspace:*",
    "@natamox/xlsx-chart-converter-resvg": "workspace:*",
    "@natamox/xlsx-chart-converter-echarts": "workspace:*",
    "@natamox/xlsx-chart-converter-svg": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
