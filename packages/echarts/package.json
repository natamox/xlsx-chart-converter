{
  "name": "@natamox/xlsx-chart-converter-echarts",
  "version": "0.1.0",
  "description": "ECharts SSR SVG renderer adapter for xlsx-chart-converter Chart IR.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
