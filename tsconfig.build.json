{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "packages",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["packages/*/test/**/*.ts", "dist", "coverage"]
}
